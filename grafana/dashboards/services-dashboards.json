          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#73BF69", "value": 1 }
            ]
          },
          "color": { "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid",
        "textMode": "value",
