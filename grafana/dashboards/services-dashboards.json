    {
      "id": 4,
      "type": "stat",
      "title": "Backend Response Time",
      "description": "Current response time for the Backend API probe in milliseconds. Green indicates fast response, orange is moderate latency, and red signals high latency that may impact user experience.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_duration_seconds{job=\"backend-api\"} * 1000",
          "legendFormat": "Backend Response",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 500 },
              { "color": "#FF4444", "value": 2000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "pluginVersion": "10.0.0"
    },
