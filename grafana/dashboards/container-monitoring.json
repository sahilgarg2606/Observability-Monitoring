        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(container_memory_usage_bytes{name!=\"\"})",
          "refId": "A",
          "legendFormat": "__auto",
          "editorMode": "code",
          "range": true
