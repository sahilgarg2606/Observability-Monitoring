      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showValues": "auto", "calcs": [] }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Transactions Trend",
