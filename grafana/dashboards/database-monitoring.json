      "title": "📊 Connection & Transaction Trends",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Active Connections Trend",
      "description": "Trend of active database backend connections over time. Red dashed line indicates the critical threshold at 20.",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(pg_stat_database_numbackends)",
          "legendFormat": "Active Connections",
          "range": true
