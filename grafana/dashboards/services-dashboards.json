    {
      "id": 6,
      "type": "stat",
      "title": "Backend HTTP Status",
      "description": "HTTP status code returned by the Backend API probe. A 200 status code means the service is healthy, any other code indicates a potential issue.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_http_status_code{job=\"backend-api\"}",
          "legendFormat": "Backend HTTP",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "from": 200,
                "to": 200,
                "result": { "text": "200 Healthy", "color": "#73BF69", "index": 0 }
              },
              "type": "range"
            },
            {
              "options": {
                "from": 201,
                "to": 599,
                "result": { "text": "Unhealthy", "color": "#FF4444", "index": 1 }
              },
              "type": "range"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#73BF69", "value": 200 }
            ]
          },
          "color": { "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid",
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "pluginVersion": "10.0.0"
    },
    {
