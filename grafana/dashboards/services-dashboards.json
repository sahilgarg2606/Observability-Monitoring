    {
      "id": 8,
      "type": "gauge",
      "title": "Backend Uptime",
      "description": "Overall uptime percentage for the Backend API over the selected time range. Calculated as the average probe success rate. 99%+ is excellent, 95-99% is acceptable, below 90% needs immediate attention.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(probe_success{job=\"backend-api\"}[$__range]) * 100",
          "legendFormat": "Backend Uptime",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 90 },
              { "color": "#FADE2A", "value": 95 },
              { "color": "#73BF69", "value": 99 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true,
        "showThresholdLabels": true,
        "orientation": "auto",
        "text": {}
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Invoice Uptime",
      "description": "Overall uptime percentage for the Invoice API over the selected time range. Calculated as the average probe success rate. 99%+ is excellent, 95-99% is acceptable, below 90% needs immediate attention.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(probe_success{job=\"invoice-api\"}[$__range]) * 100",
          "legendFormat": "Invoice Uptime",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 90 },
              { "color": "#FADE2A", "value": 95 },
              { "color": "#73BF69", "value": 99 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true,
        "showThresholdLabels": true,
        "orientation": "auto",
        "text": {}
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "SSL Certificate — Days Remaining",
      "description": "Number of days until the SSL certificate for the Backend API expires. Below 30 days requires renewal planning, below 15 days is urgent, and expired certificates will cause service outages.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"backend-api\"} - time()) / 86400",
          "legendFormat": "SSL Expiry",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 365,
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 15 },
              { "color": "#FADE2A", "value": 30 },
              { "color": "#73BF69", "value": 60 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true,
        "showThresholdLabels": true,
        "orientation": "auto",
        "text": {}
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Active Alerts",
      "description": "Total count of currently firing alerts across all monitored services. Zero alerts is ideal (green), 1-2 alerts is a warning (orange), 3+ alerts indicates a critical situation requiring immediate response.",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ALERTS{alertstate=\"firing\"}) OR vector(0)",
          "legendFormat": "Firing Alerts",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 1 },
              { "color": "#FF4444", "value": 3 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid",
        "textMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 12,
      "type": "row",
      "title": "📊 Response Time & Latency Trends",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "API Response Time Trend",
      "description": "Tracks the response time trend for Backend and Invoice APIs over time. A threshold line at 2000ms marks the critical latency boundary. Spikes above this line indicate performance degradation requiring investigation.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_duration_seconds{job=\"backend-api\"} * 1000",
          "legendFormat": "Backend API",
          "refId": "A",
          "editorMode": "code",
          "range": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_duration_seconds{job=\"invoice-api\"} * 1000",
          "legendFormat": "Invoice API",
          "refId": "B",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF4444", "value": 2000 }
            ]
          },
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Response Time (ms)",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Backend API" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Invoice API" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showValues": "value", "calcs": ["lastNotNull", "mean", "max"] }
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Duration Phases",
      "description": "Breaks down the HTTP request duration into individual phases (DNS lookup, connect, TLS handshake, processing, transfer) for both Backend and Invoice APIs. Helps identify which phase contributes most to latency.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_http_duration_seconds{job=\"backend-api\"}",
          "legendFormat": "Backend — {{phase}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_http_duration_seconds{job=\"invoice-api\"}",
          "legendFormat": "Invoice — {{phase}}",
          "refId": "B",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Duration (s)",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Backend — resolve" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Backend — connect" },
