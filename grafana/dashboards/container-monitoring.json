  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "transparent": true,
      "options": {
        "mode": "markdown",
        "content": "# 🐳 Container Monitoring\nReal-time CPU, memory, network, and health metrics for all Docker containers",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running Containers",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(container_last_seen{name!=\"\"})",
          "refId": "A",
          "legendFormat": "__auto",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#5794F2",
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false,
        "text": {
          "valueSize": 44
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total CPU Usage",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100",
          "refId": "A",
          "legendFormat": "__auto",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 60 },
              { "color": "#FF4444", "value": 80 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false
      }
    },
