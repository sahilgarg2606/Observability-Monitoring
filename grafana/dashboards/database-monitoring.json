      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "description": "Percentage of data reads served from cache. Target: >95%",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read)) * 100",
          "legendFormat": "__auto",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#FF9830", "value": 80 },
              { "color": "#FADE2A", "value": 90 },
              { "color": "#73BF69", "value": 95 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto",
