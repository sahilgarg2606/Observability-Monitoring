      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))",
          "legendFormat": "__auto",
