              { "color": "#FF9830", "value": 3221225472 },
              { "color": "#FF4444", "value": 4294967296 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
