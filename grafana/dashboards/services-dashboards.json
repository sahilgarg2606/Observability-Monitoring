    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "transparent": true,
      "options": {
        "mode": "markdown",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false },
        "content": "# 🌐 Service & Application Monitoring\nReal-time health, performance, and availability of all monitored services and APIs",
        "reduceOptions": { "calcs": [], "fields": "", "values": false }
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Backend API Status",
      "description": "Shows the current probe success status for the Backend API. UP means the service is reachable and healthy, DOWN means it is unreachable or returning errors.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "probe_success{job=\"backend-api\"}",
          "legendFormat": "Backend API",
          "refId": "A",
          "editorMode": "code",
          "range": true,
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN", "color": "#FF4444", "index": 0 },
                "1": { "text": "UP", "color": "#73BF69", "index": 1 }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4444", "value": null },
              { "color": "#73BF69", "value": 1 }
            ]
          },
          "color": { "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid",
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "text": { "titleSize": 14, "valueSize": 40 }
      },
      "pluginVersion": "10.0.0"
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Invoice API Status",
